{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "docs#dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["metadata#update", "^build:types", "^build"]
    },
    "nuxt#dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["composables#build", "plugins#build"]
    },
    "test": {
      "cache": true,
      "outputs": []
    },
    "build": {
      "outputs": ["./dist/**"],
      "dependsOn": ["test"]
    },
    "build:types": {
      "outputs": ["$TURBO_ROOT$/types/**"]
    },
    "//#tokens": {
      "cache": false
    },
    "docs#build": {
      "cache": false,
      "dependsOn": ["//#tokens", "metadata#update", "^build:types", "^build"]
    },
    "plugins#build": {
      "outputs": ["$TURBO_ROOT$/dist/plugins/**"],
      "dependsOn": ["test", "utils#build"]
    },
    "composables#build": {
      "outputs": ["$TURBO_ROOT$/dist/composables/**"],
      "dependsOn": ["test"]
    },
    "utils#build": {
      "outputs": ["$TURBO_ROOT$/dist/utils/**"],
      "dependsOn": ["test"]
    },
    "nuxt#build": {
      "outputs": ["$TURBO_ROOT$/dist/nuxt/**"],
      "dependsOn": ["test", "composables#build", "plugins#build"]
    },
    "lint": {
      "cache": true,
      "outputs": []
    },
    "update": {
      "cache": false,
      "outputs": ["./packages/metadata/index.json"]
    },
    "//#t:release": {
      "cache": false,
      "dependsOn": [
        "^test",
        "^build:types",
        "composables#build",
        "plugins#build",
        "nuxt#build"
      ]
    }
  }
}
